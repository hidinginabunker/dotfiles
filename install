#!/usr/bin/env bash

set -e

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WARNINGS=()

link() {
  ln -sfv "$DOTFILES/$1" "$HOME/$2"
}

check() {
  local cmd=$1 label=$2
  if ! command -v "$cmd" &>/dev/null; then
    WARNINGS+=("$label not found — install it for $cmd configs to take effect")
  fi
}

clean() {
  echo "Removing dead symlinks from $HOME..."
  find "$HOME" -maxdepth 1 -type l | while read -r link; do
    if [ ! -e "$link" ]; then
      rm -v "$link"
    fi
  done
}

check zsh      "zsh"
check brew     "Homebrew"
check starship "Starship"
check git      "git"
check vim      "vim"
check tmux     "tmux"

clean

link zshrc         .zshrc
link zprofile      .zprofile
link profile       .profile
link gitconfig     .gitconfig
link gitignore     .gitignore
link vimrc         .vimrc
link tmux.conf     .tmux.conf
link editorconfig  .editorconfig
link eslintrc      .eslintrc
mkdir -p "$HOME/.config"
link starship.toml .config/starship.toml

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo ""
  echo "Warnings:"
  for w in "${WARNINGS[@]}"; do
    echo "  ⚠  $w"
  done
fi

echo ""
echo "Done."
